# ====================================================================
# ChartsonArc: Environment Configuration
# Add credentials to activate real Circle Developer-Controlled Wallets API
# ====================================================================

# Port for the Node.js Express server to listen on
PORT=3000

# Your Circle Developer Console API Key (starts with "TEST_API_KEY:" or "LIVE_API_KEY:")
CIRCLE_API_KEY=

# Circle Developer-Controlled Wallet ID
CIRCLE_WALLET_ID=

# Destination / Merchant Wallet Address (where USDC payments will be received)
CIRCLE_DESTINATION_WALLET_ID=

# Your entity secret in hex format
CIRCLE_ENTITY_SECRET=

# Token ID for USDC token on the sandbox/network
CIRCLE_USDC_TOKEN_ID=

# Gemini AI API Key for chart image analysis
GEMINI_API_KEY=

# XAI (Grok) API Key for advanced analysis
XAI_API_KEY=
